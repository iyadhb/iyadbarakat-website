---
// Homepage hero. Image lives in /public/assets (already optimized in a prior pass);
// kept as a plain <img> so the /assets/ URL and dimensions stay identical to the old site.
---
<section class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="kicker">For consultants &amp; strategy professionals</div>
      <h1>Make AI think like a senior partner — not a <span>search box</span>.</h1>
      <p class="lead">The six frameworks and 100 prompts that turn AI into a consulting-grade thinking partner. Start free.</p>
      <div class="cta-row">
        <a class="btn btn-gold" href="/#newsletter">Get the frameworks + sample prompts — free →</a>
        <a class="btn btn-outline" href="/book/">Explore the book →</a>
      </div>
      <p class="hero-trust">By Iyad Barakat — author of <em>The Consulting Prompt Playbook</em> · Cambridge &amp; MIT executive education · 26+ years in consulting.</p>
    </div>
    <div class="hero-photo">
      <img src="/assets/iyad-barakat.jpg" alt="Iyad Barakat" width="480" height="480" fetchpriority="high" decoding="async" />
    </div>
  </div>
</section>
