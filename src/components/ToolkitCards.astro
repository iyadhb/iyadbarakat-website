---
// The Toolkit storefront — a data-driven 4-card value ladder. Reusable on landing pages
// by passing a different `cards` array (or override the heading via props).
export interface ToolkitCard {
  label: string;
  pill?: string;
  badge?: string;
  title: string;
  body: string;
  ctaText: string;
  ctaHref: string;
  ctaClass?: 'btn-gold' | 'btn-navy' | 'btn-ghost';
  external?: boolean;
  featured?: boolean;
}

interface Props {
  kicker?: string;
  heading?: string;
  subhead?: string;
  cards?: ToolkitCard[];
  showGuarantee?: boolean;
  id?: string;
}

const VAULT_URL = 'https://iyad.lemonsqueezy.com/checkout/buy/efc6fe74-0a2e-441c-8831-675862e47618';
const OS_URL = 'https://iyad.lemonsqueezy.com/checkout/buy/f859db53-faaf-4764-a01b-53eadc6224d3';
const AMAZON_URL = 'https://www.amazon.com/dp/B0G5HBCZG2';

const defaultCards: ToolkitCard[] = [
  {
    label: 'Free',
    title: 'The 6 Frameworks',
    body: 'Six thinking structures that make AI reason like a consultant — plus 6 ready-to-run sample super-prompts to use today.',
    ctaText: 'Get them free →',
    ctaHref: '/#newsletter',
    ctaClass: 'btn-ghost',
  },
  {
    label: '$5.99 Kindle · $16.99 Paperback',
    title: 'The Consulting Prompt Playbook',
    body: 'The full method: 6 frameworks + 100 prompts, explained with real consulting examples.',
    ctaText: 'Buy on Amazon →',
    ctaHref: AMAZON_URL,
    ctaClass: 'btn-navy',
    external: true,
  },
  {
    label: '$39',
    pill: 'Book readers $19',
    badge: 'Most popular',
    featured: true,
    title: 'The Vault',
    body: 'Stop rebuilding the same deliverables. 100 ready-to-run prompts — market entry, board decks, due diligence — each with its framework, template, and how to adapt it.',
    ctaText: 'Unlock the Vault →',
    ctaHref: VAULT_URL,
    ctaClass: 'btn-gold',
    external: true,
  },
  {
    label: '$79',
    title: 'The Operating System',
    body: 'The whole system working for you: an AI assistant pre-loaded with the frameworks, 12 done-for-you playbooks, and 100 advanced prompts. Blank page to board-ready in minutes.',
    ctaText: 'Get the Operating System →',
    ctaHref: OS_URL,
    ctaClass: 'btn-navy',
    external: true,
  },
];

const {
  kicker = 'Tools & Resources',
  heading = 'From the book to your complete AI system.',
  subhead = 'Everything you need to put the frameworks to work — start free, go as deep as you like.',
  cards = defaultCards,
  showGuarantee = true,
  id = 'toolkit',
} = Astro.props;
---
<section class="toolkit" id={id}>
  <div class="wrap">
    <div class="section-head">
      <div class="kicker">{kicker}</div>
      <h2>{heading}</h2>
      <p>{subhead}</p>
    </div>
    <div class="tk-grid">
      {cards.map((c) => (
        <div class={c.featured ? 'tk-card tk-featured' : 'tk-card'}>
          {c.badge && <div class="tk-badge">{c.badge}</div>}
          <div class="tk-label">
            {c.label}{c.pill && <span class="tk-pill">{c.pill}</span>}
          </div>
          <h3>{c.title}</h3>
          <p>{c.body}</p>
          {/* TODO: when the real Amazon rating exists, render <div class="tk-rating">★★★★★ [AMAZON_RATING]</div> on the book card */}
          <a
            class={`btn ${c.ctaClass ?? 'btn-navy'} tk-btn`}
            href={c.ctaHref}
            {...(c.external ? { target: '_blank', rel: 'noopener' } : {})}
          >{c.ctaText}</a>
        </div>
      ))}
    </div>
    {showGuarantee && (
      <p class="tk-guarantee">Every purchase is backed by a 14-day, no-questions-asked money-back guarantee.</p>
    )}
  </div>
</section>
