---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title="Insights: AI for Consultants — Frameworks, Prompts & Workflows | Iyad Barakat"
  description="Practical insights on using AI as a consulting-grade thinking partner — frameworks, prompts, and workflows for strategy professionals."
  ogImage={new URL('/assets/og-blog.png', Astro.site).href}
>
  <section>
    <div class="wrap">
      <div class="section-head">
        <div class="kicker">Insights</div>
        <h2>Notes on consulting in the AI era</h2>
        <p>Frameworks, prompts, and workflows for using AI as a genuine thinking partner.</p>
      </div>
      {posts.length === 0 ? (
        <p style="text-align:center;color:var(--grey);">New posts coming soon.</p>
      ) : (
        <ul class="post-list">
          {posts.map((p) => (
            <li class="post-item">
              <a href={`/blog/${p.id}/`}>
                {p.data.heroImage && (
                  <img
                    class="post-thumb"
                    src={p.data.heroImage}
                    alt={p.data.title}
                    width="1200"
                    height="630"
                    loading="lazy"
                    decoding="async"
                  />
                )}
                <div class="post-body">
                  <h3>{p.data.title}</h3>
                  <p>{p.data.description}</p>
                  <span class="post-date">{fmt(p.data.publishDate)}</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .post-list {
    list-style: none; max-width: 960px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 26px;
  }
  .post-item a {
    display: flex; flex-direction: column; height: 100%; overflow: hidden;
    background: #fff; border: 1px solid var(--line); border-radius: 12px;
    transition: transform .18s, box-shadow .18s;
  }
  .post-item a:hover { transform: translateY(-3px); box-shadow: 0 16px 30px rgba(31,58,95,0.12); }
  .post-thumb {
    width: 100%; aspect-ratio: 1200 / 630; object-fit: cover; display: block;
    background: var(--paper); border-bottom: 1px solid var(--line);
  }
  .post-body { padding: 22px 24px 24px; display: flex; flex-direction: column; flex: 1; }
  .post-item h3 { font-size: 19px; color: var(--navy); margin-bottom: 8px; line-height: 1.3; }
  .post-item p { font-size: 14.5px; color: var(--grey); margin-bottom: 14px; line-height: 1.55; flex: 1; }
  .post-date { font-size: 12.5px; color: var(--gold); font-weight: 600; letter-spacing: .3px; }
  @media (max-width: 720px) { .post-list { grid-template-columns: 1fr; } }
</style>
