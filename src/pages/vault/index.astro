---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'The Consulting Prompt Vault — companion resource for readers | Iyad Barakat';
const description =
  'The Consulting Prompt Vault is the companion resource for readers of The Consulting Prompt Playbook — the 100 prompts from the book, organised by the six frameworks. Redeem the code from your copy.';
---
<BaseLayout
  title={title}
  description={description}
  ogImage={new URL('/assets/og-vault.png', Astro.site).href}
>
  <section class="vault" id="vault-hero">
    <div class="wrap">
      <div class="section-head">
        <div class="kicker">For readers</div>
        <h2>The Consulting Prompt Vault</h2>
        <p>The companion resource for readers of <em>The Consulting Prompt Playbook</em>: the 100 prompts referenced in the book, organised by the six frameworks — each with its template and adaptation notes, in a Notion workspace you copy and keep.</p>
      </div>
    </div>
  </section>

  <section class="frameworks" id="redeem">
    <div class="wrap">
      <div class="section-head">
        <div class="kicker">How to get it</div>
        <h2>Redeem the code from your book.</h2>
        <p>The Vault is a reader companion — it comes with the book. Your code is printed in the back matter of <em>The Consulting Prompt Playbook</em>. Enter it on the Reader Bonus page and we'll send your Vault link.</p>
      </div>
      <div style="text-align:center;margin-top:8px;">
        <a class="btn btn-gold" href="/bonus/">Redeem your reader code →</a>
      </div>
      <p style="text-align:center;color:var(--grey);font-size:14px;margin-top:18px;">Code not working? Email <a href="mailto:info@iyadbarakat.com" style="color:var(--navy);">info@iyadbarakat.com</a> with a photo of your receipt or the book page and we'll sort it out.</p>
    </div>
  </section>

  <section class="vault" id="not-a-reader">
    <div class="wrap">
      <div class="section-head">
        <div class="kicker">Not a reader yet?</div>
        <h2>The Vault code is inside the book.</h2>
        <p>The book is available <a href="https://www.amazon.com/dp/B0G5HBCZG2" target="_blank" rel="noopener" style="color:var(--navy);">on Amazon</a> — the Vault code is inside. Prefer to start free? Get the six consulting AI frameworks (plus six sample prompts) by email below.</p>
      </div>
      <div class="newsletter-form" style="max-width:480px;margin:8px auto 0;">
        <script is:inline async data-uid="e13384b663" src="https://iyad-barakat.kit.com/e13384b663/index.js"></script>
      </div>
    </div>
  </section>
</BaseLayout>
