---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'The Consulting AI Operating System — design-partner research | Iyad Barakat';
const description =
  'A workflow system, in development, for producing defensible client recommendations with AI — evidence traceable, assumptions explicit, judgement and accountability human. A small design-partner cohort is being prepared.';

// Interim "express interest" action — a pre-filled email. The five draft
// qualification questions are seeded into the body so interest doubles as
// qualification.
// TODO: replace with the Kit qualification form once Cowork finalises the 5
// questions (form should apply tag `dp-interest` on submit).
const interestSubject = 'Design-partner research — expression of interest';
const interestBody = [
  "I'd like to express interest in the Consulting AI Operating System design-partner research.",
  '',
  'A little about my work:',
  '1. What type of consulting work do you do?',
  '2. What recommendation-led deliverable do you produce repeatedly?',
  '3. How are you currently using Claude or ChatGPT in your work?',
  '4. What is the biggest risk or source of rework in your current process?',
  '5. Would you be willing to test a guided workflow using anonymised, synthetic or approved material?',
].join('\n');
const interestHref = `mailto:info@iyadbarakat.com?subject=${encodeURIComponent(interestSubject)}&body=${encodeURIComponent(interestBody)}`;
---
<BaseLayout
  title={title}
  description={description}
  ogImage={new URL('/assets/og-operating-system.png', Astro.site).href}
>
  <section class="vault" id="os-hero">
    <div class="wrap">
      <div class="section-head">
        <div class="kicker">In development</div>
        <h2>Produce defensible client recommendations with AI — without delegating judgement or accountability</h2>
        <p>AI agents can now do meaningful parts of consulting's research, analysis and drafting. The hard part is directing that work so the result is something you can stand behind: evidence traceable, assumptions explicit, judgement and final responsibility staying human. That discipline is what I call <a href="/blog/the-agentic-consultant/" style="color:var(--navy);">the agentic consultant</a>'s way of working.</p>
      </div>
    </div>
  </section>

  <section class="frameworks" id="what">
    <div class="wrap">
      <div class="section-head">
        <div class="kicker">What is being built</div>
        <h2>One workflow, done properly.</h2>
        <p>The Consulting AI Operating System is a workflow system for exactly that. It is currently in development and being tested around one workflow: turning mixed client evidence into an accountable recommendation brief — with an evidence register, claim-status labelling (sourced, calculated, estimated or uncertain), defined human review gates, and a final sign-off that stays with the consultant.</p>
        <p>The system uses four levels of control: instructional (checklists and status labels), workflow (mandatory checkpoints), technical (source capture), and professional (human approval and stated limitations). It does not guarantee accuracy, confidentiality or compliance — no AI system can — and it is designed on precisely that understanding.</p>
      </div>
    </div>
  </section>

  <section class="frameworks" id="who">
    <div class="wrap">
      <div class="section-head">
        <div class="kicker">Who it is for</div>
        <h2>A narrow fit, on purpose.</h2>
        <p>Independent consultants who personally produce recommendation-led client work from mixed evidence, use Claude or ChatGPT at least weekly, and remain personally accountable for what they deliver.</p>
      </div>
    </div>
  </section>

  <section class="vault" id="design-partner">
    <div class="wrap">
      <div class="section-head">
        <div class="kicker">Design-partner research</div>
        <h2>A small founding cohort is being prepared.</h2>
        <p>A small founding design-partner cohort is being prepared to test the first workflow on anonymised, synthetic or explicitly approved material. If this is the kind of work you do, you can express interest below. Places are limited and qualification matters more than speed.</p>
      </div>
      <div style="text-align:center;margin-top:8px;">
        <a class="btn btn-gold" href={interestHref}>Express interest in the design-partner research →</a>
      </div>
    </div>
  </section>
</BaseLayout>
