---
import BaseLayout from './BaseLayout.astro';
import AuthorBox from '../components/AuthorBox.astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  author?: string;
  tags?: string[];
  heroImage?: string;
  canonical?: string;
  tldr?: string;
  faq?: { q: string; a: string }[];
  slug: string;
}

const {
  title,
  description,
  publishDate,
  updatedDate,
  author = 'Iyad Barakat',
  heroImage,
  canonical,
  tldr,
  faq,
  slug,
} = Astro.props;

const url = new URL(`/blog/${slug}/`, Astro.site).href;
const canonicalUrl = canonical ?? url;
const ogImage = heroImage
  ? new URL(heroImage, Astro.site).href
  : new URL('/assets/og-image.jpg', Astro.site).href;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  dateModified: (updatedDate ?? publishDate).toISOString(),
  author: { '@type': 'Person', name: author, url: 'https://iyadbarakat.com/#about' },
  publisher: { '@type': 'Person', name: 'Iyad Barakat' },
  image: ogImage,
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://iyadbarakat.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://iyadbarakat.com/blog/' },
    { '@type': 'ListItem', position: 3, name: title, item: url },
  ],
};

// GEO: when a post supplies FAQ pairs, advertise them as FAQPage rich results.
const faqSchema = faq && faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    }
  : null;

const schemas = [articleSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];
---
<BaseLayout
  title={`${title} | Iyad Barakat`}
  description={description}
  canonical={canonicalUrl}
  ogType="article"
  ogImage={ogImage}
  schema={schemas}
>
  <article class="post">
    <div class="wrap post-wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a> › <a href="/blog/">Blog</a> › <span>{title}</span>
      </nav>
      <h1>{title}</h1>
      <p class="post-meta">
        By {author} · <time datetime={publishDate.toISOString()}>{fmt(publishDate)}</time>
        {updatedDate && <> · Updated {fmt(updatedDate)}</>}
      </p>
      {heroImage && (
        <img
          class="hero"
          src={heroImage}
          alt={title}
          width="1200"
          height="630"
          loading="eager"
          decoding="async"
        />
      )}
      {tldr && (
        <p class="tldr"><strong>TL;DR —</strong> {tldr}</p>
      )}
      <div class="prose">
        <slot />
      </div>
      <AuthorBox author={author} />
    </div>
  </article>
</BaseLayout>

<style>
  .post { padding: 56px 0 80px; }
  .post-wrap { max-width: 720px; }
  .crumbs { font-size: 12.5px; color: var(--grey); margin-bottom: 22px; }
  .crumbs a { color: var(--navy); }
  .post h1 { font-size: clamp(28px, 5vw, 38px); color: var(--navy); line-height: 1.2; margin-bottom: 12px; }
  .post-meta { font-size: 13.5px; color: var(--grey); margin-bottom: 26px; }
  .hero { display: block; width: 100%; height: auto; aspect-ratio: 1200 / 630; border-radius: 8px; margin: 0 0 30px; background: var(--line); }
  .tldr {
    background: #fff; border-left: 3px solid var(--gold); border-radius: 4px;
    padding: 16px 20px; margin-bottom: 34px; font-size: 15.5px; color: var(--ink); line-height: 1.6;
  }
  .tldr strong { color: var(--navy); }
  .prose { font-size: 16.5px; color: var(--ink); line-height: 1.75; }
  .prose :global(h2) { font-family: 'Playfair Display', Georgia, serif; font-size: 24px; color: var(--navy); margin: 36px 0 12px; }
  .prose :global(h3) { font-family: 'Playfair Display', Georgia, serif; font-size: 19px; color: var(--navy); margin: 28px 0 10px; }
  .prose :global(p) { margin-bottom: 18px; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 18px 22px; }
  .prose :global(li) { margin-bottom: 8px; }
  .prose :global(a) { color: var(--navy); font-weight: 600; text-decoration: underline; text-decoration-color: var(--gold); }
  .prose :global(strong) { color: var(--navy); }
  .prose :global(blockquote) { border-left: 3px solid var(--line); padding-left: 18px; color: var(--grey); font-style: italic; margin: 0 0 18px; }
  .prose :global(img) { border-radius: 6px; margin: 24px 0; }
  .prose :global(figure) { margin: 30px 0; }
  .prose :global(figure svg) { width: 100%; height: auto; display: block; border: 1px solid var(--line); border-radius: 8px; background: #fff; }
  .prose :global(figcaption) { font-size: 13px; color: var(--grey); text-align: center; margin-top: 10px; }
  .prose :global(code) { background: #F0EDE4; padding: 2px 6px; border-radius: 3px; font-size: 0.9em; }
</style>
