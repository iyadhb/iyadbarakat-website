---
// Reusable campaign landing-page template. Drive it with props (from an .astro page
// or MDX frontmatter). A new landing page = one file, no hand-built HTML.
import BaseLayout from './BaseLayout.astro';
import ToolkitCards from '../components/ToolkitCards.astro';
import FaqSection from '../components/FaqSection.astro';
import type { FaqItem } from '../components/FaqSection.astro';

interface Props {
  title: string;
  description: string;
  kicker?: string;
  headline: string;
  subhead?: string;
  ctaText?: string;
  ctaHref?: string;
  showToolkit?: boolean;
  faq?: FaqItem[];
  canonical?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  kicker,
  headline,
  subhead,
  ctaText,
  ctaHref = '/#newsletter',
  showToolkit = false,
  faq,
  canonical,
  noindex = false,
} = Astro.props;
---
<BaseLayout title={title} description={description} canonical={canonical} noindex={noindex}>
  <section class="hero">
    <div class="hero-inner lp-hero">
      {kicker && <div class="kicker">{kicker}</div>}
      <h1>{headline}</h1>
      {subhead && <p class="lead lp-lead">{subhead}</p>}
      {ctaText && (
        <div class="cta-row lp-cta">
          <a class="btn btn-gold" href={ctaHref}>{ctaText}</a>
        </div>
      )}
    </div>
  </section>

  <section>
    <div class="wrap lp-body-wrap">
      <div class="lp-body">
        <slot />
      </div>
    </div>
  </section>

  {showToolkit && <ToolkitCards />}

  {faq && faq.length > 0 && (
    <section>
      <FaqSection items={faq} />
    </section>
  )}
</BaseLayout>

<style>
  .lp-hero { display: block; text-align: center; max-width: 760px; }
  .lp-lead { margin-left: auto; margin-right: auto; }
  .lp-cta { justify-content: center; margin-top: 28px; }
  .lp-body-wrap { max-width: 720px; }
  .lp-body { font-size: 16.5px; color: var(--ink); line-height: 1.75; }
  .lp-body :global(h2) { font-family: 'Playfair Display', Georgia, serif; font-size: 24px; color: var(--navy); margin: 34px 0 12px; }
  .lp-body :global(p) { margin-bottom: 18px; }
  .lp-body :global(ul) { margin: 0 0 18px 22px; }
  .lp-body :global(a) { color: var(--navy); font-weight: 600; }
</style>
